{
  "version": "cn-1.0",
  "steps": [
    {
      "id": "customer",
      "label": "客户信息",
      "fields": [
        {
          "name": "email",
          "type": "email",
          "label": "电子邮箱",
          "validators": [{ "name": "required" }, { "name": "email" }],
          "grid": { "mobile": 12, "desktop": 12 }
        },
        {
          "name": "firstName",
          "type": "text",
          "label": "名",
          "validators": [{ "name": "required" }],
          "grid": { "mobile": 12, "desktop": 6 }
        },
        {
          "name": "lastName",
          "type": "text",
          "label": "姓",
          "validators": [{ "name": "required" }],
          "grid": { "mobile": 12, "desktop": 6 }
        },
        {
          "name": "mobileNumber",
          "type": "text",
          "label": "手机号码",
          "validators": [{ "name": "required" }],
          "grid": { "mobile": 12, "desktop": 6 }
        },
        {
          "name": "altMobileNumber",
          "type": "text",
          "label": "备用电话",
          "validators": [],
          "grid": { "mobile": 12, "desktop": 6 }
        },
        {
          "name": "marketing",
          "type": "checkbox",
          "label": "我同意接收 ORANGE 及其合作伙伴的促销、产品和服务信息。",
          "validators": [],
          "grid": { "mobile": 12, "desktop": 12 }
        },
        {
          "name": "deliveryAddress",
          "type": "group",
          "label": "收货地址",
          "fields": [
            {
              "name": "region",
              "type": "text",
              "label": "省 / 直辖市",
              "validators": [{ "name": "required" }],
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "city",
              "type": "text",
              "label": "城市",
              "validators": [{ "name": "required" }],
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "district",
              "type": "text",
              "label": "区 / 县",
              "validators": [{ "name": "required" }],
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "addressLine1",
              "type": "text",
              "label": "详细地址",
              "validators": [{ "name": "required" }],
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "addressLine2",
              "type": "text",
              "label": "楼栋、单元、房号",
              "validators": [],
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "postalCode",
              "type": "text",
              "label": "邮政编码",
              "validators": [
                { "name": "required" },
                { "name": "maxLength", "value": 6 }
              ],
              "asyncValidators": [{ "name": "serviceablePostalCode" }],
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "deliveryEmail",
              "type": "email",
              "label": "收货通知邮箱",
              "validators": [{ "name": "required" }, { "name": "email" }],
              "grid": { "mobile": 12, "desktop": 6 }
            }
          ],
          "grid": { "mobile": 12, "desktop": 12 }
        },
        {
          "name": "billingAddress",
          "type": "group",
          "label": "账单地址",
          "fields": [
            {
              "name": "sameAsDeliveryAddress",
              "type": "checkbox",
              "label": "与收货地址相同",
              "defaultValue": true,
              "validators": [],
              "grid": { "mobile": 12, "desktop": 12 }
            },
            {
              "name": "firstName",
              "type": "text",
              "label": "名",
              "validators": [{ "name": "required" }],
              "visibleIf": { "field": "sameAsDeliveryAddress", "value": false },
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "lastName",
              "type": "text",
              "label": "姓",
              "validators": [{ "name": "required" }],
              "visibleIf": { "field": "sameAsDeliveryAddress", "value": false },
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "region",
              "type": "text",
              "label": "省 / 直辖市",
              "validators": [{ "name": "required" }],
              "visibleIf": { "field": "sameAsDeliveryAddress", "value": false },
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "city",
              "type": "text",
              "label": "城市",
              "validators": [{ "name": "required" }],
              "visibleIf": { "field": "sameAsDeliveryAddress", "value": false },
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "addressLine1",
              "type": "text",
              "label": "详细地址",
              "validators": [{ "name": "required" }],
              "visibleIf": { "field": "sameAsDeliveryAddress", "value": false },
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "postalCode",
              "type": "text",
              "label": "邮政编码",
              "validators": [
                { "name": "required" },
                { "name": "maxLength", "value": 6 }
              ],
              "visibleIf": { "field": "sameAsDeliveryAddress", "value": false },
              "grid": { "mobile": 12, "desktop": 6 }
            },
            {
              "name": "taxId",
              "type": "text",
              "label": "纳税人识别号",
              "validators": [],
              "visibleIf": { "field": "sameAsDeliveryAddress", "value": false },
              "grid": { "mobile": 12, "desktop": 6 }
            }
          ],
          "grid": { "mobile": 12, "desktop": 12 }
        }
      ]
    },
    {
      "id": "shipping",
      "label": "配送方式",
      "component": "shipping-options",
      "fields": [
        {
          "name": "shippingMethod",
          "type": "radio-card",
          "label": "配送方式",
          "validators": [{ "name": "required" }],
          "options": [
            { "label": "标准配送", "value": "standard", "price": 30 },
            { "label": "快速配送", "value": "express", "price": 60 }
          ]
        }
      ]
    },
    {
      "id": "payment",
      "label": "支付",
      "component": "payment-methods",
      "fields": [
        {
          "name": "paymentMethod",
          "type": "payment-card",
          "label": "支付方式",
          "validators": [{ "name": "required" }],
          "options": [
            {
              "label": "银行卡 / 银联",
              "value": "unionpay",
              "icon": "credit_card"
            },
            {
              "label": "支付宝",
              "value": "alipay",
              "icon": "account_balance_wallet"
            },
            { "label": "微信支付", "value": "wechat-pay", "icon": "qr_code" }
          ]
        }
      ]
    }
  ]
}
